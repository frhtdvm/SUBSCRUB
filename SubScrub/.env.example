# SubScrub – App Environment Variables
# Copy to .env and fill in real values for production builds
# Without these, the app runs in Demo Mode automatically

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Your self-hosted Plaid broker URL
EXPO_PUBLIC_PLAID_BROKER_BASE_URL=

# ─── Google OAuth / Gmail ─────────────────────────────────────────────────────
# From Google Cloud Console > OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=

# ─── Microsoft OAuth / Outlook ────────────────────────────────────────────────
# From Azure Portal > App Registrations
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# From RevenueCat Dashboard > Project > App > API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ─── Note ────────────────────────────────────────────────────────────────────
# All keys are optional. The app will run in Demo Mode if none are set.
# Demo Mode shows realistic demo data for all features.
