# SubScrub — Environment Variables Template
# Copy this file to .env.local for local development.
# For EAS builds, set these via: eas secret:create --scope project --name KEY --value VALUE
#
# All EXPO_PUBLIC_* variables are bundled into the JS bundle at build time.
# They are visible in the bundle — never store server-side secrets here.
# Server-side secrets (Plaid client_secret) go ONLY in the plaid-broker/.env

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Base URL of your deployed plaid-broker instance (see infra/plaid-broker/)
EXPO_PUBLIC_PLAID_BROKER_BASE_URL=

# ─── Google OAuth (Gmail) ─────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# OAuth 2.0 Client ID — iOS and Android have separate client IDs
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─── Microsoft OAuth (Outlook) ───────────────────────────────────────────────
# Create at: https://portal.azure.com → App registrations
EXPO_PUBLIC_MS_CLIENT_ID=
EXPO_PUBLIC_MS_TENANT_ID=common

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# Dashboard: https://app.revenuecat.com → Project → API Keys
# Use the PUBLIC key (starts with "appl_" for iOS, "goog_" for Android)
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ─── App environment marker ──────────────────────────────────────────────────
# Set automatically by eas.json profiles. Do not override manually.
EXPO_PUBLIC_APP_ENV=development
